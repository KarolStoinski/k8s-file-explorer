{
  "name": "k8s-file-explorer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "dev:ensure": "node scripts/ensure-vite-dev.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 1420",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:mac": "tauri build --bundles dmg",
    "tauri:build:mac:universal": "tauri build --target universal-apple-darwin --bundles dmg",
    "mac:release:verify": "bash scripts/verify-macos-release.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "lucide": "^1.16.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}

{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "k8s-file-explorer",
  "version": "0.1.0",
  "identifier": "com.karol.k8sfileexplorer",
  "build": {
    "beforeDevCommand": "npm run dev:ensure",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "k8s-file-explorer",
        "width": 1280,
        "height": 820,
        "minWidth": 1000,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
